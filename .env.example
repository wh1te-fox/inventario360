# Variables de entorno para Railway / producción
# NO subir valores reales de contraseña.

# Puerto (Railway lo proporciona automáticamente, pero puedes dejarlo si quieres local):
PORT=3002

# MySQL (proporcionadas por Railway plugin MySQL)
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=inventario360

# CORS (url de tu app Railway)
ALLOWED_ORIGINS=http://localhost:3002,https://inventario360-production.up.railway.app

# Node env
NODE_ENV=production
